# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build outputs
dist/
build/
out/
*.js.map
*.d.ts.map

# Generated enclave artifacts under placeholders/cf-pages. The build writes copies
# here, but CI reads ONLY the static inputs from this dir (_headers, _routes.json,
# logo.png, favicon.png, sigstore/) and deploys the freshly-built dist/enclave. Keep
# those inputs tracked; ignore everything the build regenerates so it stops being
# committed dirt.
/placeholders/cf-pages/index.html
/placeholders/cf-pages/manifest.json
/placeholders/cf-pages/.well-known/kms-manifest.json
/placeholders/cf-pages/enclave.css
/placeholders/cf-pages/enclave.*.css
/placeholders/cf-pages/enclave-client.*.js
/placeholders/cf-pages/kms-worker.*.js
/placeholders/cf-pages/kms-worker.*.meta.json

# Test coverage
coverage/
.nyc_output/
*.lcov

# Environment variables
.env
.env.local
.env.*.local
.env.production

# IDE and editor files
.vscode/
.idea/
.claude/
*.swp
*.swo
*~
.DS_Store

# OS files
Thumbs.db
Desktop.ini

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp

# Build artifacts (not content-addressed)
# Content-addressed artifacts (kms-<hash>.mjs) should be committed for verification
dist/*.mjs
!dist/kms-*.mjs
dist/*.js
!dist/kms-*.js

# Sigstore artifacts (may want to commit these for transparency)
# Uncomment if you want to gitignore them:
# *.sig
# *.cert
# *.bundle

# Lock files (commit these for reproducible builds)
# Do NOT ignore package-lock.json, pnpm-lock.yaml, or yarn.lock
# They are critical for deterministic builds

# Local verification cache
.verify-cache/

# Development certificates
*.pem
*.key
*.crt

# Test artifacts
test-results/
playwright-report/
test-output/

# Documentation builds
docs/.vitepress/dist/
docs/.vitepress/cache/

# Demo build artifacts
example/**/dist-*/
.coverage-readme-data.json

# Docker files (deployment-specific, not for public use)
Dockerfile
docker-compose.yml
.dockerignore
DOCKER.md
